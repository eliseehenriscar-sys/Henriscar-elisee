import sqlite3
import hashlib
import datetime
from getpass import getpass

# ====================== CONEXÃO COM O BANCO ======================
def conectar_db():
    conn = sqlite3.connect('sisvenda.db')
    conn.row_factory = sqlite3.Row
    return conn

def criar_tabelas():
    conn = conectar_db()
    cursor = conn.cursor()
    
    # Usuários (Login)
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS usuarios (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            username TEXT UNIQUE NOT NULL,
            password TEXT NOT NULL,
            nome TEXT
        )
    ''')
    
    # Clientes
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS clientes (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nome TEXT NOT NULL,
            cpf TEXT UNIQUE,
            telefone TEXT,
            email TEXT,
            endereco TEXT,
            data_cadastro TEXT
        )
    ''')
    
    # Produtos
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS produtos (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nome TEXT NOT NULL,
            codigo TEXT UNIQUE,
            preco REAL NOT NULL,
            estoque INTEGER DEFAULT 0,
            descricao TEXT
        )
    ''')
    
    # Vendas
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS vendas (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            data_venda TEXT,
            cliente_id INTEGER,
            usuario_id INTEGER,
            valor_total REAL,
            FOREIGN KEY (cliente_id) REFERENCES clientes(id),
            FOREIGN KEY (usuario_id) REFERENCES usuarios(id)
        )
    ''')
    
    # Itens da Venda
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS itens_venda (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            venda_id INTEGER,
            produto_id INTEGER,
            quantidade INTEGER,
            preco_unitario REAL,
            FOREIGN KEY (venda_id) REFERENCES vendas(id),
            FOREIGN KEY (produto_id) REFERENCES produtos(id)
        )
    ''')
    
    conn.commit()
    conn.close()

# ====================== HASH DE SENHA ======================
def hash_senha(senha):
    return hashlib.sha256(senha.encode()).hexdigest()

# ====================== LOGIN ======================
def login():
    conn = conectar_db()
    cursor = conn.cursor()
    
    print("\n=== LOGIN ===")
    username = input("Usuário: ")
    senha = getpass("Senha: ")
    senha_hash = hash_senha(senha)
    
    cursor.execute("SELECT id, nome FROM usuarios WHERE username = ? AND password = ?", 
                  (username, senha_hash))
    usuario = cursor.fetchone()
    conn.close()
    
    if usuario:
        print(f"Bem-vindo, {usuario['nome']}!")
        return usuario['id']
    else:
        print("Usuário ou senha incorretos!")
        return None

