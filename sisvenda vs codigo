# ====================== CADASTRO DE CLIENTE ======================
def cadastrar_cliente():
    print("\n=== CADASTRO DE CLIENTE ===")
    nome = input("Nome: ")
    cpf = input("CPF (opcional): ")
    telefone = input("Telefone: ")
    email = input("Email: ")
    endereco = input("Endereço: ")
    data = datetime.date.today().isoformat()
    
    conn = conectar_db()
    cursor = conn.cursor()
    try:
        cursor.execute('''
            INSERT INTO clientes (nome, cpf, telefone, email, endereco, data_cadastro)
            VALUES (?, ?, ?, ?, ?, ?)
        ''', (nome, cpf, telefone, email, endereco, data))
        conn.commit()
        print("Cliente cadastrado com sucesso!")
    except sqlite3.IntegrityError:
        print("Erro: CPF já cadastrado!")
    conn.close()

# ====================== CADASTRO DE PRODUTO ======================
def cadastrar_produto():
    print("\n=== CADASTRO DE PRODUTO ===")
    nome = input("Nome do produto: ")
    codigo = input("Código do produto: ")
    try:
        preco = float(input("Preço (R$): "))
        estoque = int(input("Estoque inicial: "))
    except ValueError:
        print("Valor inválido!")
        return
    
    descricao = input("Descrição: ")
    
    conn = conectar_db()
    cursor = conn.cursor()
    try:
        cursor.execute('''
            INSERT INTO produtos (nome, codigo, preco, estoque, descricao)
            VALUES (?, ?, ?, ?, ?)
        ''', (nome, codigo, preco, estoque, descricao))
        conn.commit()
        print("Produto cadastrado com sucesso!")
    except sqlite3.IntegrityError:
        print("Erro: Código já existe!")
    conn.close()

# ====================== REGISTRAR VENDA ======================
def registrar_venda(usuario_id):
    print("\n=== REGISTRAR VENDA ===")
    
    # Escolher cliente
    conn = conectar_db()
    cursor = conn.cursor()
    cursor.execute("SELECT id, nome FROM clientes")
    clientes = cursor.fetchall()
    
    if not clientes:
        print("Cadastre um cliente primeiro!")
        conn.close()
        return
    
    print("\nClientes disponíveis:")
    for c in clientes:
        print(f"{c['id']} - {c['nome']}")
    
    try:
        cliente_id = int(input("\nID do cliente: "))
    except:
        print("ID inválido!")
        conn.close()
        return
    
    # Itens da venda
    itens = []
    valor_total = 0.0
    
    while True:
        cursor.execute("SELECT id, nome, preco, estoque FROM produtos")
        produtos = cursor.fetchall()
        
        print("\nProdutos disponíveis:")
        for p in produtos:
            print(f"{p['id']} - {p['nome']} | R$ {p['preco']:.2f} | Estoque: {p['estoque']}")
        
        try:
            prod_id = int(input("\nID do produto (0 para finalizar): "))
            if prod_id == 0:
                break
            quantidade = int(input("Quantidade: "))
            
            cursor.execute("SELECT nome, preco, estoque FROM produtos WHERE id = ?", (prod_id,))
            produto = cursor.fetchone()
            
            if not produto:
                print("Produto não encontrado!")
                continue
            if produto['estoque'] < quantidade:
                print("Estoque insuficiente!")
                continue
            
            subtotal = produto['preco'] * quantidade
            valor_total += subtotal
            itens.append((prod_id, quantidade, produto['preco']))
            
            print(f"Adicionado: {quantidade}x {produto['nome']} = R$ {subtotal:.2f}")
            
        except:
            print("Entrada inválida!")
    
    if not itens:
        print("Venda cancelada.")
        conn.close()
        return
    
    # Registrar venda
    data = datetime.datetime.now().isoformat()
    cursor.execute('''
        INSERT INTO vendas (data_venda, cliente_id, usuario_id, valor_total)
        VALUES (?, ?, ?, ?)
    ''', (data, cliente_id, usuario_id, valor_total))
    venda_id = cursor.lastrowid
    
    # Registrar itens e atualizar estoque
    for prod_id, qtd, preco in itens:
        cursor.execute('''
            INSERT INTO itens_venda (venda_id, produto_id, quantidade, preco_unitario)
            VALUES (?, ?, ?, ?)
        ''', (venda_id, prod_id, qtd, preco))
        
        # Atualizar estoque
        cursor.execute("UPDATE produtos SET estoque = estoque - ? WHERE id = ?", (qtd, prod_id))
    
    conn.commit()
    conn.close()
    print(f"\nVenda #{venda_id} registrada com sucesso! Total: R$ {valor_total:.2f}")

